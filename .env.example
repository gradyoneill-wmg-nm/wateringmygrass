NEXT_PUBLIC_SITE_URL=https://wateringmygrass.com

# Supabase — public (client-side, LiveSessionCounter, auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server-side only (mood API route, feelings_logs writes)
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Supabase Auth — set redirect URL in Supabase dashboard:
#   Authentication > URL Configuration > Site URL = NEXT_PUBLIC_SITE_URL
#   Authentication > URL Configuration > Redirect URLs += NEXT_PUBLIC_SITE_URL/auth/callback

# GitHub — optional token for build log (unauthenticated: 60 req/hr limit)
GITHUB_TOKEN=
